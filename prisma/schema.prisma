generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  clerkUserId   String   @unique

  // Identity (available at signup)
  username      String  @unique
  email         String?  @unique
  mobile        String?  @unique

  // Profile (filled during onboarding)
  firstName     String?
  lastName      String?
  shopName      String?
  address       String?
  gender        Gender?
  profileImageUrl String?

  // Subscription (managed later)
  subscriptionStatus   SubscriptionStatus @default( created )
  subscriptionEndDate  DateTime?
  razorpaySubscriptionId  String?            @unique   // ← ADD: links webhook to user
  subscriptionPlan    SubscriptionPlan?                    // ← ADD: "halfyearly" | "yearly"
   razorpayPaymentId  String? 
   subscriptionCreatedAt DateTime? // set when create-subscription API is called
   hadTrial                Boolean   @default(false)  // ← ADD THIS
  // System
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customers     Customer[]
   @@index([razorpaySubscriptionId])  
  @@index([subscriptionStatus, isActive])
  @@map("users")
}


model Customer {
  id         String    @id @default(uuid())
  userId     String
  name       String
  address    String
  mobile     String?
  idProofImg    String?
  customerImg     String?
  aadharNo     String?
  remark     String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  gender        Gender?
  pledges    Pledge[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])                 
  @@index([name])                      
  @@map("customers")
}


model Pledge {
  id            String   @id @default(uuid())
  customerId    String

  pledgeDate    DateTime
  loanAmount    Decimal  @db.Decimal(12,2)

  itemType      ItemType
  itemName      String
  purity        Decimal  @db.Decimal(5,2)

  grossWeight   Decimal  @db.Decimal(10,3)
  netWeight     Decimal  @db.Decimal(10,3)
  netWeightOfMetal Decimal @db.Decimal(10,3)

  interestRate  Decimal  @db.Decimal(5,2)
  compoundingDuration CompoundingDuration
  allowCompounding Boolean @default(true)
  itemPhoto     String?
  remark        String?
  durationMonths Decimal @db.Decimal(6,2)
  pledgeAudits PledgeAudit[]
  status        PledgeStatus
  releaseDate   DateTime?

  totalInterest     Decimal? @db.Decimal(12,2)
  receivableAmount  Decimal? @db.Decimal(12,2)

  // if in formula WILL change in future
  calculationVersion Int @default(1)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([customerId])
  @@map("pledges")
}

model PledgeAudit {
  id        String   @id @default(uuid())
  pledgeId  String

  // What happened
  action    AuditAction

  // Snapshot of financial inputs
  principal         Decimal @db.Decimal(12,2)
  interestRate      Decimal @db.Decimal(5,2)

  allowCompounding  Boolean
  compoundingDuration CompoundingDuration
  

  calculationVersion Int

  // Time calculation snapshot
  durationMonths    Decimal @db.Decimal(6,2)

  // Final result
  totalInterest     Decimal @db.Decimal(12,2)
  receivableAmount  Decimal @db.Decimal(12,2)

  // Context
  releaseDate       DateTime

  createdAt         DateTime @default(now())

  pledge Pledge @relation(fields: [pledgeId], references: [id], onDelete: Cascade)
  @@map("pledge_audits") // add this for consistency
  @@index([pledgeId])
}

model MetalPrice {
  id              String    @id @default(cuid())
  metal           MetalType

  usdPerOunce     Float     // source value
  inrPerGram      Float     // user-friendly

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([metal, createdAt(sort: Desc)])
}

model ExchangeRate {
  id        String   @id @default(cuid())
  from      String   // "USD"
  to        String   // "INR"
  rate      Float
  createdAt DateTime @default(now())

  @@index([from, to, createdAt(sort: Desc)])
}

enum Gender {
  Male
  Female
  Other
}

enum AuditAction {
  CREATED
  UPDATED
  RELEASED
  RECALCULATED
}
enum SubscriptionPlan {
  halfyearly
  yearly
}
enum SubscriptionStatus {
  trial
  created   // ← add this
  active
  halted
  expired
}

enum MetalType {
  GOLD
  SILVER
}
enum ItemType {
  GOLD
  SILVER
}

enum PledgeStatus {
  ACTIVE
  RELEASED
  OVERDUE
}

enum CompoundingDuration {
  MONTHLY
  QUARTERLY
  HALFYEARLY
  YEARLY
}
