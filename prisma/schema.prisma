generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(uuid())
  clerkUserId   String   @unique

  // Identity (available at signup)
  username      String  @unique
  email         String?  @unique
  mobile        String?  @unique

  // Profile (filled during onboarding)
  firstName     String?
  lastName      String?
  shopName      String?
  address       String?
  gender        Gender?
  profileImageUrl String?

  // Subscription (managed later)
  subscriptionStatus   SubscriptionStatus @default( created )
  subscriptionEndDate  DateTime?
  razorpaySubscriptionId  String?            @unique   // ← ADD: links webhook to user
  subscriptionPlan    SubscriptionPlan?                    // ← ADD: "halfyearly" | "yearly"
   razorpayPaymentId  String? 
   subscriptionCreatedAt DateTime? // set when create-subscription API is called
   hadTrial                Boolean   @default(false)  // ← ADD THIS
  // System
  isActive      Boolean  @default(true)
  lastLoginAt   DateTime?
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  customers     Customer[]
   @@index([razorpaySubscriptionId])  
  @@index([subscriptionStatus, isActive])
  @@map("users")
}


model Customer {
  id         String    @id @default(uuid())
  userId     String
  name       String
   region    String   // city / area / locality
  address    String
  mobile     String?
   viewToken String   @unique   // ✅ important
  idProofImg    String?
  customerImg     String?
  aadharNo     String?
  remark     String?
  deletedAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  gender        Gender?
  pledges    Pledge[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])                 
  @@index([name])                      
  @@map("customers")
}


model Pledge {
  id            String   @id @default(uuid())
  customerId    String

  pledgeDate    DateTime
  loanAmount    Decimal  @db.Decimal(12,2)

  interestRate  Decimal  @db.Decimal(5,2)
  compoundingDuration CompoundingDuration
  allowCompounding Boolean @default(true)
  itemPhoto     String?
  remark        String?
  durationMonths Decimal? @db.Decimal(6,2)
  pledgeAudits PledgeAudit[]
  status        PledgeStatus
  releaseDate   DateTime?

  items             PledgeItem[]
  netWeightOfGold   Decimal @db.Decimal(10,3) @default(0)
  netWeightOfSilver Decimal @db.Decimal(10,3) @default(0)

  totalInterest     Decimal? @db.Decimal(12,2)
  receivableAmount  Decimal? @db.Decimal(12,2)

  // if in formula WILL change in future
  calculationVersion Int @default(1)

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  
  transactions Transaction[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@index([status, createdAt])
  @@index([customerId])
  @@map("pledges")
}

model PledgeItem {
  id               String    @id @default(uuid())
  pledgeId         String

  itemType         ItemType   // NECKLACE, RING, BANGLE etc.
  metalType        MetalType  // GOLD | SILVER  ← drives LTV price
  itemName         String?    // optional custom name

  quantity         Int        @default(1)  // informational only

  grossWeight      Decimal    @db.Decimal(10,3)  // total for all pieces
  netWeight        Decimal    @db.Decimal(10,3)  // total for all pieces
  purity           Decimal    @db.Decimal(5,2)
  netWeightOfMetal Decimal    @db.Decimal(10,3)  // auto = netWeight × (purity/100)

  pledge Pledge @relation(fields: [pledgeId], references: [id], onDelete: Cascade)

  @@index([pledgeId])
  @@map("pledge_items")
}

model PledgeAudit {
  id        String   @id @default(uuid())
  pledgeId  String

  // What happened
  action    AuditAction

  // Snapshot of financial inputs
  principal         Decimal @db.Decimal(12,2)
  interestRate      Decimal @db.Decimal(5,2)

  allowCompounding  Boolean
  compoundingDuration CompoundingDuration
  

  calculationVersion Int

  // Time calculation snapshot
  durationMonths    Decimal? @db.Decimal(6,2)

   netWeightOfGold   Decimal @db.Decimal(10,3)
  netWeightOfSilver Decimal @db.Decimal(10,3)
  goldPricePerGram  Decimal? @db.Decimal(10,2)  // market price at release
  silverPricePerGram Decimal? @db.Decimal(10,2) // market price at release
  marketValueAtRelease Decimal? @db.Decimal(12,2)
  ltvAtRelease         Decimal? @db.Decimal(5,2)

  // Final result
  totalInterest     Decimal? @db.Decimal(12,2)
  receivableAmount  Decimal? @db.Decimal(12,2)

  // Context
  releaseDate       DateTime?

  createdAt         DateTime @default(now())

  pledge Pledge @relation(fields: [pledgeId], references: [id], onDelete: Cascade)
  @@map("pledge_audits") // add this for consistency
  @@index([pledgeId])
}

model MetalPrice {
  id              String    @id @default(cuid())
  metal           MetalType

  usdPerOunce Decimal @db.Decimal(12,4)
inrPerGram  Decimal @db.Decimal(10,2)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  @@index([createdAt])
  @@index([metal, createdAt(sort: Desc)])
}

model Transaction {
  id        String          @id @default(uuid())
  pledgeId  String
  amount    Decimal         @db.Decimal(12,2)
  type      TransactionType
  note      String?
  createdAt DateTime        @default(now())

  pledge Pledge @relation(fields: [pledgeId], references: [id], onDelete: Cascade)

  @@index([pledgeId, createdAt(sort: Desc)])
  @@map("transactions")
}

enum TransactionType {
  REPAYMENT_PRINCIPAL
  REPAYMENT_INTEREST
  TOPUP
}
model ExchangeRate {
  id        String   @id @default(cuid())
  from      String   // "USD"
  to        String   // "INR"
  rate      Float
  createdAt DateTime @default(now())

  @@index([from, to, createdAt(sort: Desc)])
}

enum Gender {
  Male
  Female
  Other
}

enum AuditAction {
  CREATED
  UPDATED
  RELEASED
   DELETED  // ✅ ADD THIS
  RECALCULATED
}
enum SubscriptionPlan {
  halfyearly
  yearly
}
enum SubscriptionStatus {
  trial
  created   // ← add this
  active
  halted
  expired
}

// Rename/replace current ItemType enum
enum ItemType {
  NECKLACE
  CHAIN
  RING
  BANGLE
  BRACELET
  EARRING
  ANKLET
  PENDANT
  COIN
  BAR
  OTHER
}

// MetalType already exists — keep as is
enum MetalType {
  GOLD
  SILVER
}
enum PledgeStatus {
  ACTIVE
  RELEASED
  OVERDUE
}

enum CompoundingDuration {
  MONTHLY
  HALFYEARLY
  YEARLY
  
}
